<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="ru.ifmo.person.model">
    <class name="ImportHistory" table="import_history">
        <id name="id" type="long" column="id">
            <generator class="identity"/>
        </id>

        <property name="status" column="status" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">ru.ifmo.person.enumeration.ImportStatus</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <property name="createdAt" type="timestamp" column="created_at" not-null="true" update="false"/>

        <property name="username" type="string" column="username"/>

        <property name="importedCount" type="int" column="imported_count"/>

        <property name="errorMessage" type="string" column="error_message" length="1000"/>
    </class>
</hibernate-mapping>
